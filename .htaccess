# Force HTTPS (except ACME/DCV validation files, which must stay reachable over HTTP)
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteCond %{REQUEST_URI} !^/\.well-known/
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect waypointmw.com to primary domain
RewriteCond %{HTTP_HOST} ^(www\.)?waypointmw\.com$ [NC]
RewriteCond %{REQUEST_URI} !^/\.well-known/
RewriteRule ^(.*)$ https://waypointmachineworks.com/$1 [L,R=301]

# Retired pages
RewriteRule ^brands(\.html)?$ https://waypointmachineworks.com/ [L,R=301]

# Remove www (except ACME/DCV validation paths — SSL.com validates via www over HTTP)
RewriteCond %{HTTP_HOST} ^www\.waypointmachineworks\.com$ [NC]
RewriteCond %{REQUEST_URI} !^/\.well-known/
RewriteRule ^(.*)$ https://waypointmachineworks.com/$1 [L,R=301]

# Remove .html extensions (clean URLs)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# Security headers
Header set X-Content-Type-Options "nosniff"
Header set X-Frame-Options "SAMEORIGIN"
Header set X-XSS-Protection "1; mode=block"
Header set Referrer-Policy "strict-origin-when-cross-origin"

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>

# Custom 404
ErrorDocument 404 /404.html

# Block directory browsing
Options -Indexes

# Never serve form logs or other .log files
<Files ~ "\.log$">
  Require all denied
</Files>
